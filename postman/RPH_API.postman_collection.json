              "raw": "{\n  \"universe\": {\n    \"name\": \"Prime Continuity\",\n    \"description\": \"Main continuity created from Postman.\",\n    \"public\": false\n  }\n}"
            },
            "url": "{{base_url}}/api/v1/universes"
          }
        },
        {
          "name": "Create Universe With Images",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "universe[name]", "value": "Image Universe", "type": "text" },
                { "key": "universe[description]", "value": "Universe with attached images.", "type": "text" },
                { "key": "universe[public]", "value": "false", "type": "text" },
                { "key": "universe[portrait_image]", "type": "file", "src": [] },
                { "key": "universe[cover_image]", "type": "file", "src": [] },
                { "key": "universe[misc_images][]", "type": "file", "src": [] }
              ]
            },
            "url": "{{base_url}}/api/v1/universes",
            "description": "Select local files in Postman before sending. Portrait max 5MB vertical, cover max 20MB horizontal, misc max 8 images at 5MB each."
          }
        },
        {
          "name": "Show Universe",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/universes/{{universe_id}}"
          }
        },
        {
          "name": "Update Universe",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"universe\": {\n    \"name\": \"Updated Prime Continuity\",\n    \"description\": \"Updated from Postman.\",\n    \"public\": true\n  }\n}"
            },
            "url": "{{base_url}}/api/v1/universes/{{universe_id}}"
          }
        }
      ]
    },
