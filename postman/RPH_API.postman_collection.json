{
  "info": {
    "_postman_id": "4b57a8c4-3eba-4556-bf5f-7e63d86c9430",
    "name": "RPH API",
    "description": "Postman collection for the RPH Rails API. Import this file plus `RPH Local` environment. Run `Auth / Signup` once, then `Auth / Login`; login saves `{{token}}` automatically. Create requests save IDs for later show/update/delete requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('status is below 500', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\",\n    \"password_confirmation\": \"{{password}}\"\n  }\n}"
            },
            "url": "{{base_url}}/api/v1/auth/signup",
            "description": "Creates a user. If this returns 422 because the email already exists, run Login next."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "}",
                  "pm.test('token was saved', function () {",
                  "  pm.expect(pm.environment.get('token')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n  }\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login",
            "description": "Logs in and stores the JWT in the `token` environment variable."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "People",
      "item": [
        {
          "name": "List People",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/people",
            "description": "Lists people owned by the authenticated user."
          }
        },
        {
          "name": "Create Person",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.environment.set('person_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"person\": {\n    \"first_name\": \"Grace\",\n    \"last_name\": \"Hopper\",\n    \"email\": \"grace.postman@example.com\",\n    \"phone\": \"555-0200\"\n  }\n}"
            },
            "url": "{{base_url}}/api/v1/people"
          }
        },
        {
          "name": "Show Person",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/people/{{person_id}}"
          }
        },
        {
          "name": "Update Person",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"person\": {\n    \"first_name\": \"Updated Grace\",\n    \"last_name\": \"Hopper\",\n    \"email\": \"updated.grace.postman@example.com\",\n    \"phone\": \"555-0300\"\n  }\n}"
            },
            "url": "{{base_url}}/api/v1/people/{{person_id}}"
          }
        }
      ]
    },
    {
      "name": "Universes",
      "item": [
        {
          "name": "List Visible Universes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/universes",
            "description": "Lists universes visible to you: your universes plus public universes from other users."
          }
        },
        {
          "name": "Search Visible Universes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/universes?q=Prime"
          }
        },
        {
          "name": "List Mine Universes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/universes/mine",
            "description": "Lists only universes created by the authenticated user."
          }
        },
        {
          "name": "Search Mine Universes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/universes/mine?q=Prime"
          }
        },
        {
          "name": "Create Universe",
          "event": [
