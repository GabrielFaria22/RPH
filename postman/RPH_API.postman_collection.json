          "request": { "method": "GET", "header": [], "url": "{{base_url}}/api/v1/relations" }
        },
        {
          "name": "Create Relation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
